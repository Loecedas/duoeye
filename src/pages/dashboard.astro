---
import DuoDashApp from '../components/DuoDashApp';
import Layout from '../layouts/Layout.astro';
import { normalizeUsername } from '../services/duolingoDataLoader';

const initialUsername = normalizeUsername(Astro.url.searchParams.get('username'));
---

<Layout title="DuoEye - 仪表盘">
  <DuoDashApp
    client:only="react"
    initialUsername={initialUsername}
  />
</Layout>
