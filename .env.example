# Duolingo Token
DUOLINGO_TOKEN=

# AI Provider (bigmodel, gemini, openrouter, deepseek, siliconflow, moonshot, zenmux, custom)
AI_PROVIDER=bigmodel

# API Keys
# BIGMODEL_API_KEY=
# ZAI_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# SILICONFLOW_API_KEY=
# MOONSHOT_API_KEY=
# ZENMUX_API_KEY=
# CUSTOM_API_KEY=

# Model Configuration
AI_MODEL=glm-4.5-flash

# Optional override. Required only when AI_PROVIDER=custom.
# AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Optional API access token for protecting this route
API_SECRET_TOKEN=
